# App
PORT=3000
NODE_ENV=production
BASE_URL=https://photos.yourdomain.com
JWT_SECRET=replace-with-64-bytes-of-hex-from-openssl-rand--hex-32
ADMIN_EMAIL=photographer@example.com
ADMIN_PASSWORD=change-me-only-used-for-the-bootstrap-seed
LOG_LEVEL=info

# Reverse-proxy hops in front of the app (VPS nginx counts as 1)
TRUSTED_PROXY_HOPS=1

# Database
DATABASE_PATH=/app/data/lumiere.db

# S3 Storage (MinIO on NAS)
S3_ENDPOINT_INTERNAL=http://nas.lan:9000
S3_ENDPOINT_PUBLIC=https://s3.photos.yourdomain.com
S3_REGION=us-east-1
S3_BUCKET=lumiere
S3_ACCESS_KEY=replace-with-scoped-svcacct-key
S3_SECRET_KEY=replace-with-scoped-svcacct-secret
S3_FORCE_PATH_STYLE=true

# MinIO bootstrap (used on the NAS only)
MINIO_ROOT_USER=lumiere-admin
MINIO_ROOT_PASSWORD=change-me

# SMTP (not used yet in foundation slice)
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com

# Limits / tuning
MAX_UPLOAD_SIZE_MB=80
IMAGE_CONCURRENCY=3
RATE_LIMIT_WINDOW_MS=60000
DOWNLOAD_RATE_LIMIT=3
PRESIGN_TTL_SECONDS=60
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Backups (litestream → off-host target)
LITESTREAM_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
LITESTREAM_S3_BUCKET=lumiere-db-backups
LITESTREAM_S3_ACCESS_KEY=
LITESTREAM_S3_SECRET_KEY=

# Optional
WATERMARK_DEFAULT_OPACITY=0.4
