Subject: Your gallery "{{galleryTitle}}" was viewed

<!doctype html>
<html>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; max-width: 560px; margin: 0 auto; padding: 32px 24px; color: #1a1a1a;">
    <h1 style="font-size: 20px; font-weight: 600; margin: 0 0 16px;">Your gallery was viewed</h1>
    <p style="margin: 0 0 12px; font-size: 15px; line-height: 1.5;">
      <strong>{{galleryTitle}}</strong> was just opened{{#if clientName}} by {{clientName}}{{/if}}.
    </p>
    {{#if galleryUrl}}
      <p style="margin: 24px 0;">
        <a href="{{galleryUrl}}" style="display: inline-block; padding: 10px 16px; background: #111; color: #fff; border-radius: 6px; text-decoration: none; font-size: 14px;">Open gallery</a>
      </p>
    {{/if}}
    <p style="margin: 24px 0 0; font-size: 12px; color: #888;">
      You're receiving this because notifications are enabled for this gallery. You can turn them off in the gallery settings.
    </p>
  </body>
</html>
